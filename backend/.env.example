# Backend Environment Variables

# MongoDB
MONGODB_URI=mongodb://localhost:27017/nms
# یا MongoDB Atlas کے لیے:
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/nms

# JWT سیکریٹ کلید
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# سرور پوری
PORT=3000

# Node Env
NODE_ENV=development

# فائلیں اپ لوڈ کرنے کی جگہ
UPLOADS_DIR=./uploads

# CORS اجازت دیں
CORS_ORIGIN=http://localhost:3000

# Socket.io سرور URL
SOCKET_URL=http://localhost:3000
